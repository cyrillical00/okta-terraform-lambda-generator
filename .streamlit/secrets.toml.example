# Copy this file to .streamlit/secrets.toml and fill in real values.
# Never commit secrets.toml to git.

ANTHROPIC_API_KEY = "sk-ant-..."
GITHUB_TOKEN = "github_pat_..."
GITHUB_REPO = "your-username/your-repo-name"

# Optional: override the model if your account restricts which models are available.
# Check console.anthropic.com/settings/limits for what your account can access.
# ANTHROPIC_MODEL = "claude-haiku-4-5-20251001"

# ── Okta live environment (optional) ──────────────────────────────────────────
# When set, the tool will fetch real group/app/event hook IDs from your Okta org
# and inject them into generation so Claude can produce `data` source lookups
# instead of blank var.* placeholders.
#
# OKTA_ORG_URL: full base URL of your org, e.g. https://dev-123456.okta.com
# OKTA_API_TOKEN: an Okta API token with read access to groups, apps, event hooks
#
# OKTA_ORG_URL = "https://dev-123456.okta.com"
# OKTA_API_TOKEN = "00abc123..."

# ── AWS live environment (optional) ───────────────────────────────────────────
# When set, the tool will fetch real Lambda function names/ARNs and IAM role ARNs
# so Claude can generate data source lookups for existing infrastructure.
#
# AWS_REGION: region your Lambda functions live in, e.g. us-east-1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: explicit credentials (omit to use
#   the instance/container role when running on AWS infrastructure).
#
# AWS_REGION = "us-east-1"
# AWS_ACCESS_KEY_ID = "AKIA..."
# AWS_SECRET_ACCESS_KEY = "..."

# ── Google OAuth — required for the login gate ────────────────────────────────
# Setup: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URI: https://your-app-name.streamlit.app/oauth2callback
[auth]
redirect_uri = "https://your-app-name.streamlit.app/oauth2callback"
cookie_secret = "replace-with-random-32-char-string"

[auth.google]
client_id = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
